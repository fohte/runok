{
  $schema: 'https://docs.renovatebot.com/renovate-schema.json',
  extends: [
    'github>fohte/renovate-config:base.json5',
    'github>fohte/renovate-config:rust.json5',
  ],
  packageRules: [
    // docs/ site dependencies are not part of the runok CLI release.
    // Use 'docs:' so PR titles distinguish docs-only updates from CLI updates;
    // release-please keeps 'docs' hidden, so no version bump or CHANGELOG entry.
    {
      matchFileNames: ['docs/**'],
      commitMessagePrefix: 'docs:',
      semanticCommitScope: null,
    },
    // docs/ dependencies: automerge patch for all, minor for devDependencies only.
    // Production deps (astro, starlight, etc.) need manual review for minor
    // updates due to potential breaking changes in the framework ecosystem.
    {
      matchFileNames: ['docs/**'],
      matchUpdateTypes: ['patch'],
      automerge: true,
    },
    {
      matchFileNames: ['docs/**'],
      matchDepTypes: ['devDependencies', 'packageManager'],
      matchUpdateTypes: ['minor'],
      automerge: true,
    },
    // starlight-links-validator 0.25+ requires Astro v7 / Starlight 0.41.
    // Hold updates until the Astro v7 upgrade lands; 0.24.1 broke .mdx link
    // validation, so even patch bumps must not slip through automerge.
    {
      matchFileNames: ['docs/**'],
      matchPackageNames: ['starlight-links-validator'],
      enabled: false,
    },
    // Cargo dev-dependencies use depType 'dev-dependencies' (hyphenated),
    // but the shared config only matches npm-style 'devDependencies'.
    // Override here to prevent release-please version bumps for dev-only crates.
    {
      matchManagers: ['cargo'],
      matchDepTypes: ['dev-dependencies'],
      commitMessagePrefix: 'chore:',
      semanticCommitScope: null,
    },
  ],
}
